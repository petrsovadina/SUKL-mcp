# Notion CRM Integration
# Create a Notion integration at https://www.notion.so/my-integrations
# Share all 3 databases with the integration
NOTION_API_KEY=ntn_your_notion_integration_token

# Notion database IDs (created via Notion MCP under "SUKL MCP — CRM" page)
NOTION_DB_LEADS=1c851a6a887d49198b4bdd29275b8ac2
NOTION_DB_ENTERPRISE=edc64118b1424db48d33a2ebafb41b2f
NOTION_DB_NEWSLETTER=2e03cd2171b94ce6a1d0e3e97093daa0

# Resend Email Integration (optional — forms work without this)
# Create API key at https://resend.com/api-keys
# Verify sender domain at https://resend.com/domains
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_OWNER_EMAIL=your@email.com
